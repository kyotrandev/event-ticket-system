NODE_ENV=development
APP_PORT=4000
APP_NAME="Event Ticket System"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:4000

DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=root
DATABASE_PASSWORD=secret
DATABASE_NAME=event_ticket_db
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

# File upload: "local" | "s3" | "s3-presigned" | "cloudinary"
FILE_DRIVER=local
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_S3_REGION=
AWS_DEFAULT_S3_BUCKET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@eventticket.dev
MAIL_DEFAULT_NAME=EventTicket
MAIL_CLIENT_PORT=1080

# Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-32
AUTH_REFRESH_TOKEN_EXPIRES_IN=7d
AUTH_FORGOT_SECRET=change-me-generate-with-openssl-rand-hex-32
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=change-me-generate-with-openssl-rand-hex-32
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

REDIS_HOST=localhost
REDIS_PORT=6379
WORKER_HOST=redis://localhost:6379/1

# Stripe test keys — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# QR HMAC secret — minimum 32 chars, change before production
TICKET_QR_SECRET=change-me-minimum-32-chars-random-secret-here
