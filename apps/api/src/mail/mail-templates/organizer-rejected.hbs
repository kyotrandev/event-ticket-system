<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organizer Application Update</title>
</head>
<body style="margin:0;font-family:arial">
    <table style="border:0;width:100%">
        <tr style="background:#eeeeee">
            <td style="padding:20px;color:#808080;text-align:center;font-size:40px;font-weight:600">
                {{app_name}}
            </td>
        </tr>
        <tr>
            <td style="padding:20px;color:#808080;font-size:16px;font-weight:100">
                Hi {{firstName}},<br><br>
                We were unable to approve your organizer application at this time.<br><br>
                If you believe this is a mistake or have questions, please contact our support team.
            </td>
        </tr>
        <tr>
            <td style="padding:0 20px 20px;color:#aaaaaa;font-size:13px">
                {{app_name}} Support
            </td>
        </tr>
    </table>
</body>
</html>
