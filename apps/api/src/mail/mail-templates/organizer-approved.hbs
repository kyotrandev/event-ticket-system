<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organizer Account Approved</title>
</head>
<body style="margin:0;font-family:arial">
    <table style="border:0;width:100%">
        <tr style="background:#eeeeee">
            <td style="padding:20px;color:#808080;text-align:center;font-size:40px;font-weight:600">
                {{app_name}}
            </td>
        </tr>
        <tr>
            <td style="padding:20px;color:#808080;font-size:16px;font-weight:100">
                Hi {{firstName}},<br><br>
                Your organizer account has been approved! You can now create and publish events on {{app_name}}.<br><br>
                Log in to get started.
            </td>
        </tr>
        <tr>
            <td style="text-align:center;padding-bottom:20px">
                <a href="{{loginUrl}}"
                    style="display:inline-block;padding:20px;background:#00838f;text-decoration:none;color:#ffffff">Log In</a>
            </td>
        </tr>
    </table>
</body>
</html>
